APP_ENV=staging
APP_URL=https://staging.postmerce.pl
APP_TIMEZONE=Europe/Warsaw
APP_SECRET=change-me-on-server
ENCRYPTION_KEY=change-me-on-server

POSTGRES_DB=postmerce
POSTGRES_USER=postmerce
POSTGRES_PASSWORD=change-me-on-server

POSTMERCE_BIND_PORT=4501
POSTMERCE_STORAGE_DIR=/srv/data/postmerce/storage
POSTMERCE_POSTGRES_DATA_DIR=/srv/data/postmerce/postgres

MAX_UPLOAD_MB=500
MAX_DURATION_SECONDS=43200
MAX_VIDEO_WIDTH=3840
MAX_VIDEO_HEIGHT=3840
CLEANUP_AFTER_DAYS=30

DRY_RUN=true

ENABLE_YOUTUBE=true
ENABLE_LINKEDIN=true
ENABLE_INSTAGRAM=false
ENABLE_FACEBOOK=false
ENABLE_TIKTOK=false

WORKER_POLL_MS=5000
WORKER_LOCK_SECONDS=300
WORKER_BATCH_SIZE=5

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://staging.postmerce.pl/oauth/youtube/callback
YOUTUBE_UPLOAD_CATEGORY_ID=22

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://staging.postmerce.pl/oauth/linkedin/callback

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://staging.postmerce.pl/oauth/meta/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://staging.postmerce.pl/oauth/tiktok/callback
