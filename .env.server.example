APP_ENV=staging
APP_URL=https://postmerce-91-99-63-80.sslip.io
APP_TIMEZONE=Europe/Warsaw
APP_SECRET=change-me-on-server
ENCRYPTION_KEY=change-me-on-server

POSTGRES_DB=postmerce
POSTGRES_USER=postmerce
POSTGRES_PASSWORD=change-me-on-server

POSTMERCE_BIND_PORT=4501
