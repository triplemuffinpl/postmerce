    "@fastify/static": "^9.1.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "pg": "^8.16.0",
    "zod": "^3.25.49"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
