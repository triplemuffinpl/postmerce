---
import "../styles/site.css";

const workflowSteps = [
  {
    title: "Wgraj materiał",
    text: "Dodaj jeden film jako źródło kampanii. Postmerce trzyma media, metadane i powiązane publikacje w jednym miejscu.",
  },
  {
    title: "Zbuduj bazowy post",
    text: "Ustal intencję, tytuł, opis i hashtagi bez udawania, że ten sam komunikat pasuje do każdej platformy.",
  },
  {
    title: "Dopasuj targety",
    text: "Każda platforma dostaje osobne konto, opis, ustawienia widoczności, termin i status publikacji.",
  },
  {
    title: "Wyślij do kolejki",
    text: "Targety trafiają do kolejki, a worker wykonuje publikację poza panelem operatora.",
  },
  {
    title: "Kontroluj status",
    text: "Widzisz, co jest zaplanowane, co czeka, co poszło, co wymaga retry i gdzie potrzebna jest reakcja.",
  },
  {
    title: "Powtarzaj proces",
    text: "Duplikuj targety, poprawiaj warianty i utrzymuj historię publikacji bez arkuszy, DM-ów i ręcznych checklist.",
  },
];

const proofCards = [
  {
    label: "Targety per platforma",
    value: "osobny opis, konto i termin",
  },
  {
    label: "Kalendarz publikacji",
    value: "plan widoczny dla całego workflow",
  },
  {
    label: "Statusy i retry",
    value: "kontrola po wysłaniu do kolejki",
  },
];

const screenshotPanels = [
  {
    src: "/screenshots/app-calendar.png",
    alt: "Postmerce publishing calendar with platform targets",
    label: "Calendar",
  },
  {
    src: "/screenshots/app-control.png",
    alt: "Postmerce control center with target-level publishing statuses",
    label: "Control",
  },
  {
    src: "/screenshots/app-posts.png",
    alt: "Postmerce post list with publishing workflow data",
    label: "Posts",
  },
];

const audienceCards = [
  {
    title: "Twórcy i founderzy",
    text: "Dla osób, które regularnie publikują video i chcą widzieć proces zamiast pamiętać o nim w głowie.",
  },
  {
    title: "Zespoły marketingowe",
    text: "Dla małych zespołów, które muszą pilnować kont, wersji, terminów i statusów bez ciężkiego social suite.",
  },
  {
    title: "Agencje",
    text: "Dla operatorów, którzy obsługują wiele publikacji i potrzebują target-level kontroli zamiast rozproszonych ustaleń.",
  },
];

const faqs = [
  {
    question: "Czy Postmerce zastępuje kalendarz social media?",
    answer:
      "Kalendarz jest tylko jednym widokiem. Postmerce trzyma cały proces: media, bazowy post, targety, konta, kolejkę, statusy, retry i historię.",
  },
  {
    question: "Czy każdy kanał może mieć inne copy?",
    answer:
      "Tak. Bazowy post jest punktem wyjścia, a target platformowy może mieć własny tytuł, opis, hashtagi, konto, termin i opcje publikacji.",
  },
  {
    question: "Co jest najważniejszą różnicą?",
    answer:
      "Postmerce traktuje publikację jak workflow po platformach, nie jak jeden przycisk. Najważniejsze są targety, statusy i kontrola po stronie operatora.",
  },
  {
    question: "Dla kogo jest Postmerce?",
    answer:
      "Dla ludzi i zespołów, które publikują video na kilku platformach i chcą mniej ręcznego pilnowania, a więcej widocznego procesu.",
  },
];
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Postmerce - multi-platform publishing control center</title>
    <meta
      name="description"
      content="Postmerce pomaga przygotować, zaplanować i kontrolować publikacje video na wielu platformach z targetami, kolejką i statusem każdego wyjścia."
    />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  </head>
  <body>
    <main class="page-shell">
      <nav class="topbar" aria-label="Primary">
        <a class="brand" href="/" aria-label="Postmerce home">
          <span class="brand-mark">P</span>
          <span>Postmerce</span>
        </a>
        <div class="nav-links">
          <a href="#workflow">Workflow</a>
          <a href="#product">Product</a>
          <a href="#faq">FAQ</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </nav>

      <section class="hero hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Publishing control center</p>
          <h1>Jeden film. Osobna publikacja dla każdej platformy.</h1>
          <p class="lead">
            Postmerce zamienia materiał video w kontrolowany workflow: bazowy post,
            platformowe targety, wybrane konta, harmonogram, kolejkę i status każdej
            publikacji.
          </p>
          <div class="hero-actions">
            <a class="button" href="mailto:support@postmerce.pl">Zarezerwuj dostęp</a>
            <a class="button secondary" href="#product">Zobacz produkt</a>
          </div>
          <div class="proof-strip" aria-label="Product proof points">
            {
              proofCards.map((item) => (
                <div>
                  <span>{item.label}</span>
                  <strong>{item.value}</strong>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="screenshot-stack" aria-label="Postmerce product screenshots">
          {
            screenshotPanels.map((panel, index) => (
              <figure class={`screenshot-card screenshot-card-${index + 1}`}>
                <span>{panel.label}</span>
                <img src={panel.src} alt={panel.alt} loading={index === 0 ? "eager" : "lazy"} />
              </figure>
            ))
          }
        </aside>
      </section>

      <section class="section motion-section" aria-label="Product animation">
        <div>
          <p class="eyebrow">Product motion</p>
          <h2>Zobacz, jak jeden materiał przechodzi przez cały workflow.</h2>
          <p>
            Animacja pokazuje rdzeń Postmerce: materiał źródłowy, targety dla
            platform, kalendarz, centrum kontroli i statusy publikacji.
          </p>
        </div>
        <figure class="motion-frame">
          <video
            src="/videos/postmerce-product-showcase.mp4"
            poster="/screenshots/app-dashboard.png"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
          ></video>
        </figure>
      </section>

      <section class="section split" aria-label="Problem">
        <div>
          <p class="eyebrow">Problem</p>
          <h2>Publikacja nie kończy się na kliknięciu “wrzuć”.</h2>
          <p>
            Ten sam materiał inaczej działa na YouTube, LinkedIn, Instagramie,
            Facebooku i TikToku. Każda platforma ma własny opis, format, konto,
            ograniczenia, termin i miejsce, w którym publikacja może utknąć.
          </p>
          <p>
            Postmerce porządkuje te decyzje w jednym systemie: od źródłowego filmu,
            przez targety i harmonogram, po statusy, błędy, retry i historię.
          </p>
        </div>
        <aside class="insight-card">
          <span>Główna zasada</span>
          <h3>Nie skaluj chaosu. Najpierw zobacz cały proces.</h3>
          <p>
            Więcej contentu pomaga dopiero wtedy, gdy wiesz, co jest przygotowane,
            gdzie ma wyjść, na jakim koncie i co wymaga reakcji.
          </p>
        </aside>
      </section>

      <section class="section" id="workflow" aria-label="Workflow">
        <p class="eyebrow">Workflow</p>
        <h2>Od jednego pliku do osobnego statusu każdego targetu.</h2>
        <div class="process-grid">
          {
            workflowSteps.map((step, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section product-section" id="product" aria-label="Product">
        <div>
          <p class="eyebrow">Product</p>
          <h2>Realny panel do codziennej kontroli publikacji.</h2>
          <p>
            Postmerce pokazuje targety w kalendarzu, daje widok kontroli dla
            operatora i pozwala pracować na poziomie pojedynczej publikacji, a nie
            tylko całej kampanii.
          </p>
        </div>
        <figure class="product-shot">
          <img src="/screenshots/app-control.png" alt="Postmerce control center screenshot" loading="lazy" />
        </figure>
      </section>

      <section class="section" aria-label="Audience">
        <p class="eyebrow">Dla kogo</p>
        <h2>Dla ludzi, którzy traktują dystrybucję video jak system.</h2>
        <div class="feature-grid">
          {
            audienceCards.map((card, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section faq-section" id="faq" aria-label="FAQ">
        <p class="eyebrow">FAQ</p>
        <h2>Konkretnie: co Postmerce porządkuje?</h2>
        <div class="faq-list">
          {
            faqs.map((item) => (
              <article>
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section final-cta" aria-label="Request access">
        <p class="eyebrow">Start</p>
        <h2>Chcesz publikować video na kilku platformach bez ręcznej kontroli w arkuszach?</h2>
        <p>
          Napisz, jeżeli chcesz zobaczyć Postmerce w praktyce i porozmawiać o
          workflow publikacji w Twoim zespole.
        </p>
        <div class="hero-actions">
          <a class="button" href="mailto:support@postmerce.pl">support@postmerce.pl</a>
          <a class="button secondary" href="/privacy">Zasady prywatności</a>
        </div>
      </section>

      <footer class="footer">
        <span>Postmerce by Triple Muffin</span>
        <div>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/data-deletion">Data deletion</a>
        </div>
      </footer>
    </main>
  </body>
</html>
