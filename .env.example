APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=4310
APP_URL=http://127.0.0.1:4310
APP_TIMEZONE=Europe/Warsaw
APP_SECRET=change-me-min-32-chars
ENCRYPTION_KEY=base64:change-me-32-byte-key

DATABASE_URL=postgres://postmerce:postmerce@127.0.0.1:55432/postmerce
STORAGE_ROOT=./storage
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

MAX_UPLOAD_MB=500
MAX_DURATION_SECONDS=43200
MAX_VIDEO_WIDTH=3840
MAX_VIDEO_HEIGHT=3840
CLEANUP_AFTER_DAYS=30

DRY_RUN=true

ENABLE_YOUTUBE=true
ENABLE_LINKEDIN=true
ENABLE_INSTAGRAM=false
ENABLE_FACEBOOK=false
ENABLE_TIKTOK=false

WORKER_POLL_MS=5000
WORKER_LOCK_SECONDS=300
WORKER_BATCH_SIZE=5

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://127.0.0.1:4310/oauth/youtube/callback
YOUTUBE_UPLOAD_CATEGORY_ID=22

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:4310/oauth/linkedin/callback

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://127.0.0.1:4310/oauth/meta/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:4310/oauth/tiktok/callback
